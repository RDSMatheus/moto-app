// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

generator customClient {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum StoreCourierStatus {
  PENDING
  ACTIVE
  BLOCKED
  KICKED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  ARRIVED_AT_STORE // motoboy chegou na loja, aguardando confirmar retirada
  IN_ROUTE // pegou o pedido, está a caminho do cliente
  DELIVERED
  CANCELLED
  EXPIRED // opcional: distinguir "cancelado pela loja" de "expirou sozinho"
}

model StoreCourier {
  id        String             @id @default(uuid())
  storeId   String
  courierId String
  status    StoreCourierStatus @default(PENDING)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  courier Courier @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@unique([storeId, courierId])
  @@index([storeId, status])
  @@index([courierId, status])
}

model Store {
  id           String   @id @default(uuid())
  name         String   @unique
  email        String   @unique
  password     String
  phone        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  state        String
  street       String
  neighborhood String
  zipCode      String
  city         String
  complement   String?
  number       String
  tenantId     String?
  cpfCnpj      String   @unique
  refreshToken String?
  latitude     Float?
  longitude    Float?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orders        Order[]
  storeCouriers StoreCourier[]
}

model Courier {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  password     String
  phone        String
  cpf          String  @unique
  refreshToken String?

  isOnline  Boolean @default(false)
  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  storeCouriers StoreCourier[]
}

model Order {
  id         Int         @id @default(autoincrement())
  storeId    String
  courierId  String?
  status     OrderStatus @default(PENDING)
  totalPrice Float
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  tenantId   String

  phone        String
  state        String
  street       String
  neighborhood String
  zipCode      String
  city         String
  complement   String?
  number       String
  latitude     Float
  longitude    Float

  acceptedAt  DateTime?
  arrivedAt   DateTime?
  inRouteAt   DateTime?
  deliveredAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  courier Courier? @relation(fields: [courierId], references: [id])
}

model Tenant {
  id          String     @id @default(uuid())
  name        String
  createdAt   DateTime   @default(now())
  plan        TenantPlan @default(BASIC)
  isActive    Boolean    @default(true)
  nextBilling DateTime?
  lastPayment DateTime?

  stores Store[]
  orders Order[]
}
